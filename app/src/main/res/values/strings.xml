    <!-- 权限引导弹窗（新增 v2.0） -->
    <!-- 首次引导 -->
    <string name="permission_guide_title">需要以下权限</string>
    <string name="permission_guide_message">📍 定位权限 - 紧急求助时发送您的位置，让联系人快速找到您\n\n📱 短信权限 - 向紧急联系人发送求助短信\n\n⚠️ 这些权限是 App 正常工作的必要条件，请放心授权。</string>
    <string name="permission_grant">授权</string>
    <string name="permission_later">暂不需要</string>

    <!-- 持续引导（拒绝后每次打开 App 都显示） -->
    <string name="permission_guide_denied_title">权限未授权，App 无法正常工作</string>
    <string name="permission_guide_denied_message">📍 定位权限未授权 - 求助短信中将无法包含您的位置信息，联系人无法找到您\n\n📱 短信权限未授权 - 无法向紧急联系人发送求助短信\n\n🔒 请点击「去授权」前往设置页面开启权限，App 才能为您提供完整的守护服务。</string>
    <string name="permission_guide_goto_settings">去授权</string>

    <!-- 后台定位权限引导 -->
    <string name="bg_location_title">需要「始终允许」定位权限</string>
    <string name="bg_location_message">「我很好」守护服务需要在后台获取您的位置，以便在您未打开 App 时也能定时检测并发送求助短信。

「使用时允许」无法在后台获取位置，因为守护服务是在 App 未运行时工作的。

请选择「始终允许」→ 定位权限 → 选择「始终」</string>
    <string name="bg_location_goto_settings">去授权</string>
    <string name="bg_location_denied_title">后台定位权限未开启</string>
    <string name="bg_location_denied_message">守护模式需要「始终允许」定位才能在后台工作。

当前定位权限为「使用时允许」，App 在后台时无法获取您的位置，守护功能将失效。

请开启后台定位权限：设置 → 应用 → 我很好 → 定位 → 始终</string>
    <string name="bg_location_skip">暂不需要</string>

    <!-- Google Play 服务检测 & 备用定位 -->
    <string name="gms_fallback_title">定位服务说明</string>
    <string name="gms_fallback_message">您的设备未安装 Google Play 服务，无法使用高精度定位。

「我很好」已自动切换到备用定位方案，定位精度可能稍低，但在紧急求助时仍可正常工作。

如果您希望使用更高精度定位，请在设备上安装 Google Play 服务。</string>
