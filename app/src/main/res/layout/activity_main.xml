<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- 内容区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ============================================================ -->
        <!-- 打卡 Tab 内容 -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/content_checkin"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- ① 打卡图片卡片（点击切换）- 延伸铺满 -->
            <FrameLayout
                android:id="@+id/layout_checkin_card"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <!-- 卡片正面 -->
                <LinearLayout
                    android:id="@+id/card_front"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/iv_checkin_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_image_placeholder"
                        android:contentDescription="@string/home_checkin_image_desc" />

                    </LinearLayout>

                    <!-- 卡片背面 -->
                    <LinearLayout
                        android:id="@+id/card_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:padding="8dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/iv_checkin_back_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_image_placeholder"
                            android:contentDescription="@string/home_checkin_back_image_desc" />

                    </LinearLayout>

            </FrameLayout>

            <!-- ② 底部按钮区域（靠近 Tab 栏） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="24dp">

                <!-- 打卡按钮 -->
                <Button
                    android:id="@+id/btn_checkin"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/home_checkin_button"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- 骑行守护按钮 -->
                <Button
                    android:id="@+id/btn_cycling"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:text="🚴 开始骑行"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/system_green"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- 骑行状态卡片（默认隐藏） -->
                <LinearLayout
                    android:id="@+id/layout_cycling_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="16dp"
                    android:visibility="gone">

                    <!-- 结束骑行按钮 -->
                    <Button
                        android:id="@+id/btn_end_cycling"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="⏹ 结束骑行"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/system_red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 3分钟未移动将自动发送求助"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginTop="12dp"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ============================================================ -->
        <!-- SOS Tab 内容 -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/content_sos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sos_hint"
                android:textSize="20sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="60dp" />

            <!-- SOS 大按钮 -->
            <Button
                android:id="@+id/btn_sos"
                android:layout_width="@dimen/sos_button_size"
                android:layout_height="@dimen/sos_button_size"
                android:text="SOS"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_sos_button" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="点击发送紧急求助"
                android:textSize="18sp"
                android:textColor="@color/text_tertiary"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_sos_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:textSize="20sp"
                android:textColor="@color/system_blue"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ============================================================ -->
        <!-- 联系人 Tab 内容 -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/content_contacts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- 守护说明卡片 -->
            <LinearLayout
                android:id="@+id/card_guardian_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_info"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="守护说明"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="若24小时未打卡，将向联系人发送位置信息。"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="APP正常运行需要："
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <!-- 短信权限行 -->
                <LinearLayout
                    android:id="@+id/layout_permission_sms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="短信权限"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_sms_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未获得"
                        android:textSize="13sp"
                        android:textColor="#FF3B30" />

                    <TextView
                        android:id="@+id/tv_sms_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="☐"
                        android:textSize="15sp"
                        android:textColor="#FF3B30" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="#F0F0F0" />

                <!-- 位置权限行 -->
                <LinearLayout
                    android:id="@+id/layout_permission_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_location_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="位置权限（需始终允许）"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_location_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未获得"
                        android:textSize="13sp"
                        android:textColor="#FF3B30" />

                    <TextView
                        android:id="@+id/tv_location_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="☐"
                        android:textSize="15sp"
                        android:textColor="#FF3B30" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="#F0F0F0" />

                <!-- GPS 定位服务行 -->
                <LinearLayout
                    android:id="@+id/layout_gps_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="定位服务（GPS）"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_gps_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未开启"
                        android:textSize="13sp"
                        android:textColor="#FF3B30" />

                    <TextView
                        android:id="@+id/tv_gps_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="☐"
                        android:textSize="15sp"
                        android:textColor="#FF3B30" />

                </LinearLayout>

            </LinearLayout>

            <!-- 图片设置 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="图片设置"
                android:textSize="14sp"
                android:textColor="@color/system_blue"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp">

                <!-- 使用图库选择 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="使用图库"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_library_a"
                            android:layout_width="60dp"
                            android:layout_height="32dp"
                            android:text="图库A"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:background="@drawable/bg_button_blue" />

                        <TextView
                            android:id="@+id/tv_library_b"
                            android:layout_width="60dp"
                            android:layout_height="32dp"
                            android:text="图库B"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:background="@color/bg_gray"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <!-- 图片库A入口 -->
                <LinearLayout
                    android:id="@+id/layout_front_image_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="图片库A"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textSize="16sp"
                        android:textColor="@color/system_blue" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <!-- 图片库B入口 -->
                <LinearLayout
                    android:id="@+id/layout_back_image_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="图片库B"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textSize="16sp"
                        android:textColor="@color/system_blue" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_contacts_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 位紧急联系人"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_contacts_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:text="@string/contacts_empty"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_contacts_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btn_add_contact_tab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/contacts_add" />

        </LinearLayout>

        <!-- ============================================================ -->
        <!-- 设置 Tab 内容 -->
        <!-- ============================================================ -->
        <ScrollView
            android:id="@+id/content_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 守护模式 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_guardian_mode"
                    android:textSize="14sp"
                    android:textColor="@color/system_blue"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="16dp">

                    <!-- 开机自启动 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_boot_auto_start"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_boot_auto_start_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_boot_auto_start"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />

                    </LinearLayout>



                    <!-- 超时时间 -->
                    <LinearLayout
                        android:id="@+id/layout_timeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_timeout"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_timeout_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_timeout_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24小时"
                            android:textSize="14sp"
                            android:textColor="@color/system_blue" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 检测频率 -->
                    <LinearLayout
                        android:id="@+id/layout_check_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测频率"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="系统多久检测一次是否需要求助"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_check_interval_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1小时"
                            android:textSize="14sp"
                            android:textColor="@color/system_blue" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                </LinearLayout>

                <!-- 短信设置 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/settings_sms_section"
                    android:textSize="14sp"
                    android:textColor="@color/system_blue"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="16dp">

                    <!-- SOS 模板选择 -->
                    <LinearLayout
                        android:id="@+id/layout_sos_template"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_sos_template"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_sos_template_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_sos_template_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_template_none"
                            android:textSize="13sp"
                            android:textColor="@color/system_blue"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=">"
                            android:textSize="16sp"
                            android:textColor="@color/system_blue" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 自动求助模板选择 -->
                    <LinearLayout
                        android:id="@+id/layout_auto_help_template"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_auto_help_template"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_auto_help_template_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_auto_help_template_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_template_none"
                            android:textSize="13sp"
                            android:textColor="@color/system_blue"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=">"
                            android:textSize="16sp"
                            android:textColor="@color/system_blue" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 骑行求助短信模板 -->
                    <LinearLayout
                        android:id="@+id/layout_cycling_template"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="骑行求助短信模板"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_cycling_template"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="骑行守护求助"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=">"
                            android:textSize="18sp"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 编辑短信（管理模板） -->
                    <LinearLayout
                        android:id="@+id/layout_edit_sms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_edit_sms"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_edit_sms_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=">"
                            android:textSize="16sp"
                            android:textColor="@color/system_blue" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 提示文字 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="（后台程序关闭自动求助和骑行求助将无法使用）"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

    <!-- ============================================================ -->
    <!-- 底部 Tab 栏 -->
    <!-- ============================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        android:background="@color/bg_white"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/tab_checkin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_checkin"
                android:textSize="12sp"
                android:textColor="@color/tab_selector" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_sos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_sos"
                android:textSize="12sp"
                android:textColor="@color/tab_selector" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_contacts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_contacts"
                android:textSize="12sp"
                android:textColor="@color/tab_selector" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_settings"
                android:textSize="12sp"
                android:textColor="@color/tab_selector" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
