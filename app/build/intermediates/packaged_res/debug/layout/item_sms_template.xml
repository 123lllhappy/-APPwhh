<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    android:padding="16dp"
    android:elevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- 标题行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textTemplateName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SOS紧急求助"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDefaultLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="默认"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="#FF9F0A"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnEditTemplate"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_edit"
            android:contentDescription="编辑"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnDeleteTemplate"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:contentDescription="删除" />

    </LinearLayout>

    <!-- 内容预览 -->
    <TextView
        android:id="@+id/textTemplateContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🆘 紧急求助！\n我的当前位置：\n纬度：{latitude}\n经度：{longitude}"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp"
        android:maxLines="3"
        android:ellipsize="end" />

</LinearLayout>